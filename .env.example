# Copy this file to .env and fill in your own Supabase project's values.
# Find these under Supabase Dashboard -> Project Settings -> API.

SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""

# Vite requires the VITE_ prefix to expose these to client-side code.
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# NEVER put SUPABASE_SERVICE_ROLE_KEY in this file or in any VITE_-prefixed
# variable. It must only exist as a server-side / edge-function secret
# (see supabase/functions and src/integrations/supabase/client.server.ts).
